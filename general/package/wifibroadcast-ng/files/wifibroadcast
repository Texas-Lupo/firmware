#!/bin/sh
wfb_key=/etc/drone.key
wfb_cfg=/etc/wfb.yaml
wfb_dev=wlan0

echo_log() {
    echo "$1" | logger -s -t wifibroadcast
}

wfb_yaml() {
    if [ -e "$1" ]; then
        while IFS=: read -r key value; do
            key=$(eval echo "$key")
            value=$(eval echo "$value")
            export "$key=$value"
        done < "$1"
    fi
}

load_config() {
    wfb_yaml /rom"$wfb_cfg"
    wfb_yaml "$wfb_cfg"
    [ ! -e "$wfb_key" ] && wfb_key=/rom"$wfb_key"
}

load_modules() {
    adapter_id=""
    for card in $(lsusb | awk '{print $6}' | uniq); do
        case "$card" in
            "0bda:8812" | "0bda:881a" | "0b05:17d2" | "2357:0101" | "2604:0012")
                driver=88XXau
                ;;

            "0bda:a81a")
                driver=8812eu
                adapter_id="bl-m8812eu2"
                ;;

            "0bda:f72b" | "0bda:b733")
                driver=8733bu
                adapter_id="bl-m8731bu4"
                ;;

            "0bda:c812" | "0bda:c82c")
                driver=88x2cu
                adapter_id="wyvern-200"
                ;;
        esac
    done

    if [ -z "$driver" ]; then
        echo_log "Wireless module not detected!"
        exit 1
    fi

    echo_log "Detected driver: $driver"
    [ -e /sys/class/net/"$wfb_dev" ] && return
    sleep 1

    if [ "$driver" != "88XXau" ]; then
        mkdir -p /lib/firmware
        cat << 'EOF' > /lib/firmware/PHY_REG_PG.txt
#[v1][Exact]#
#[2.4G] A
[1Tx] C20 ffffffff 18 18 18 18
[1Tx] C24 ffffffff 25 28 29 29
[1Tx] C28 ffffffff 19 19 19 23
[1Tx] C2C ffffffff 23 25 28 29
[1Tx] C30 ffffffff 19 19 19 19
[2Tx] C34 ffffffff 19 19 19 19
[2Tx] C38 ffffffff 19 19 19 19
[1Tx] C3C ffffffff 23 25 28 29
[1Tx] C40 ffffffff 19 19 19 19
[1Tx] C44 ffffffff 19 19 19 19
[2Tx] C48 ffffffff 19 19 19 19
[2Tx] C4C ffffffff 19 19 19 19
#[2.4G] B
[1Tx] E20 ffffffff 18 18 18 18
[1Tx] E24 ffffffff 25 28 29 29
[1Tx] E28 ffffffff 19 19 19 23
[1Tx] E2C ffffffff 23 25 28 29
[1Tx] E30 ffffffff 19 19 19 19
[2Tx] E34 ffffffff 19 19 19 19
[2Tx] E38 ffffffff 19 19 19 19
[1Tx] E3C ffffffff 23 25 28 29
[1Tx] E40 ffffffff 19 19 19 19
[1Tx] E44 ffffffff 19 19 19 19
[2Tx] E48 ffffffff 19 19 19 19
[2Tx] E4C ffffffff 19 19 19 19
#[5G] A
[1Tx] C24 ffffffff 25 28 29 29
[1Tx] C28 ffffffff 19 19 19 23
[1Tx] C2C ffffffff 23 25 28 29
[1Tx] C30 ffffffff 19 19 19 19
[2Tx] C34 ffffffff 19 19 19 19
[2Tx] C38 ffffffff 19 19 19 19
[1Tx] C3C ffffffff 23 25 28 29
[1Tx] C40 ffffffff 19 19 19 19
[1Tx] C44 ffffffff 19 19 19 19
[2Tx] C48 ffffffff 19 19 19 19
[2Tx] C4C ffffffff 19 19 19 19
#[5G] B
[1Tx] E24 ffffffff 25 28 29 29
[1Tx] E28 ffffffff 19 19 19 23
[1Tx] E2C ffffffff 23 25 28 29
[1Tx] E30 ffffffff 19 19 19 19
[2Tx] E34 ffffffff 19 19 19 19
[2Tx] E38 ffffffff 19 19 19 19
[1Tx] E3C ffffffff 23 25 28 29
[1Tx] E40 ffffffff 19 19 19 19
[1Tx] E44 ffffffff 19 19 19 19
[2Tx] E48 ffffffff 19 19 19 19
[2Tx] E4C ffffffff 19 19 19 19
#[END]#
EOF
        opt1="rtw_tx_pwr_by_rate=1"
        opt2="rtw_tx_pwr_lmt_enable=0"
    fi

    modprobe "$driver" "$opt1" "$opt2" MaxTxBufLen=12
    sleep 3

    if ! ifconfig "$wfb_dev" up; then
iw "$wfb_dev" set txpower fixed "$wfb_power"
        echo_log "Wireless driver not found!"
        exit 1
    fi

    # Set .wireless.wlan_adapter in /etc/wfb.yaml if adapter_id is set
    if [ -n "$adapter_id" ]; then
        yaml-cli-multi -i /etc/wfb.yaml -s .wireless.wlan_adapter "$adapter_id"
    fi
}

load_mlink() {
    ifconfig "$wfb_dev" mtu "$mlink"

    nalu=$((mlink - 100))
    if [ "$(cli -g .outgoing.naluSize)" != "$nalu" ]; then
        cli -s .outgoing.naluSize "$nalu"
        killall -1 majestic
    fi
}

load_interface() {
    ifconfig "$wfb_dev" up
iw "$wfb_dev" set txpower fixed "$wfb_power"
    iw "$wfb_dev" set monitor none

    if [ "$width" = "40" ]; then
        wfb_width="HT40+"
    elif [ "$width" = "10" ]; then
        wfb_width="10MHz"
    else
        wfb_width="HT20"
    fi

    iw "$wfb_dev" set channel "$channel" HT20
    iw reg set 00

    [ "$driver" = "88XXau" ] && wfb_power=$((txpower * -100)) || wfb_power=$((txpower * 50))
}

load_wfb() {
    wfb_rx -K "$wfb_key" -i "$link_id" -p "$1" -u "$3" "$wfb_dev" &> /dev/null &
    wfb_tx -K "$wfb_key" -M "$tun_index" -B "$width" -k "$fec_k" -n "$fec_n" \
        -S "$stbc" -L "$ldpc" -i "$link_id" -p "$2" -u "$4" "$wfb_dev" &> /dev/null &
}

start_broadcast() {
    echo_log "Starting wfb_tx"
    wfb_tx -K "$wfb_key" -M "$mcs_index" -B "$width" -k "$fec_k" -n "$fec_n" -U rtp_local \
        -S "$stbc" -L "$ldpc" -i "$link_id" -C 8000 -J 10 -E 5000 "$wfb_dev" &> /dev/null &
    nohup wfb_tx -k 1 -n 1 -p 8001 -C 8001 -u 11001 -K "$wfb_key" -i "$link_id" "$wfb_dev" &> /dev/null &
    nohup wfb_tx -k 1 -n 1 -p 8002 -C 8002 -u 11002 -K "$wfb_key" -i "$link_id" "$wfb_dev" &> /dev/null &
}

start_tunnel() {
    echo_log "Starting wfb_tun"
    load_wfb 160 32 5800 5801
    wfb_tun -a 10.5.0.10/24 > /dev/null &
}

start_telemetry() {
    chipset=$(ipcinfo -c)
    [ "$chipset" = "ssc33x" ] && devmem 0x1F207890 16 0x8

    port_rx=14550
    port_tx=14551

    echo_log "Starting $router"
    load_wfb 144 16 "$port_rx" "$port_tx"

    if [ "$router" = "mavfwd" ]; then
        mavfwd -b 115200 -c 8 -p 100 -a 15 -t -m /dev/"$serial" \
            -o 127.0.0.1:"$port_tx" -i 127.0.0.1:"$port_rx" > /dev/null &
    else
        if [ "$router" = "msposd" ]; then
            size=$(curl -s localhost/api/v1/config.json | jsonfilter -qe "@.video0.size")
        fi
        msposd -b 115200 -c 11 -r "$osd_fps" -m /dev/"$serial" -d  > /dev/null &

        sleep 5
        echo "&L70&F28&G8CPU:&C TEMP:&T\n&B" >/tmp/MSPOSD.msg
    fi
}

video_settings() {
    for card in $(lsusb | awk '{print $6}' | uniq); do
        case "$card" in
            "0bda:8812" | "0bda:881a" | "0b05:17d2" | "2357:0101" | "2604:0012")
                driver=88XXau
                wifibroadcast cli -s .wireless.txpower 20
                wifibroadcast cli -s .wireless.wlan_adapter bl-r8812af1
                wifibroadcast cli -s .broadcast.stbc 1
                wifibroadcast cli -s .broadcast.ldpc 1
                ;;

            "0bda:a81a")
                driver=8812eu
                wifibroadcast cli -s .wireless.txpower 40
                wifibroadcast cli -s .wireless.wlan_adapter bl-m8812eu2
                wifibroadcast cli -s .broadcast.stbc 1
                wifibroadcast cli -s .broadcast.ldpc 1
                ;;

            "0bda:f72b" | "0bda:b733")
                driver=8733bu
                wifibroadcast cli -s .wireless.txpower 20
                wifibroadcast cli -s .wireless.wlan_adapter bl-m8731bu4
                wifibroadcast cli -s .broadcast.stbc 0
                wifibroadcast cli -s .broadcast.ldpc 0
                ;;

            "0bda:c812" | "0bda:c82c")
                driver=88x2cu
                wifibroadcast cli -s .wireless.txpower 20
                wifibroadcast cli -s .wireless.wlan_adapter wyvern-200
                wifibroadcast cli -s .broadcast.stbc 1
                wifibroadcast cli -s .broadcast.ldpc 1
                ;;
        esac
    done

    sensor=$(ipcinfo -s)
    family=$(ipcinfo -f)

    if [ "$sensor" == "imx415" ]; then
    cli -s .isp.sensorConfig /etc/sensors/imx415_greg_fpvXIX-gpt200.bin
  else
    cli -s .isp.sensorConfig /etc/sensors/imx335_greg_fpvVII-gpt200.bin
  fi

    cli -s .isp.exposure 11
    cli -s .video0.fps 90
    cli -s .video0.bitrate 8000
    cli -s .video0.codec h265
    cli -s .video0.rcMode cbr
    cli -s .outgoing.enabled true
    cli -s .outgoing.wfb true
    cli -s .records.split 1
    cli -s .records.notime true
    cli -s .fpv.enabled true
    cli -s .fpv.noiseLevel 0
    cli -s .video0.gopSize 1

    wifibroadcast cli -s .wireless.mlink 1500
    wifibroadcast cli -s .wireless.link_control alink
    sed -i '/fluke/d' /etc/rc.local && sed -i -e '$i fluke > /tmp/fluke.log 2>&1 &' /etc/rc.local

    if [ "$sensor" = "imx335" ]; then
        cli -s .video0.size 1920x1440
    else
        cli -s .video0.size 1920x1080
    fi
}

start() {
    load_config
    load_modules
    load_mlink
    load_interface

    if [ ! -e /etc/system.ok ]; then
        video_settings
        touch /etc/system.ok
        killall -1 majestic
    fi

    stop
    start_broadcast
    start_tunnel
    start_telemetry
}

stop() {
    for process in wfb_rx wfb_tx wfb_tun msposd mavfwd; do
        if [ -n "$(pidof $process)" ]; then
            echo_log "Stopping $process"
            killall -q "$process"
        fi
    done
}

case "$1" in
    start|stop)
        $1
        ;;

    reset)
        cp -f /rom"$wfb_cfg" "$wfb_cfg"
        cp -f /rom/etc/majestic.yaml /etc/majestic.yaml
        video_settings
        ;;

    cli)
        shift
        yaml-cli -i "$wfb_cfg" "$@"
        ;;

    *)
        echo "Usage: $0 {start|stop|reset|cli}"
        exit 1
        ;;
esac
